from ursina import *

app = Ursina()

player = Entity(model='cube', color=color.orange, y=1)
obstacles = []

def update():
    player.x += (held_keys['d'] - held_keys['a']) * time.dt * 5

    if random.random() < 0.02:
        obstacles.append(Entity(model='cube', color=color.red, position=(0,1,20)))

    for o in obstacles:
        o.z -= time.dt * 10
        if o.intersects(player).hit:
            application.quit()

app.run()
