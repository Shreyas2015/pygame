from ursina import *

app = Ursina()

player = Entity(model='cube', color=color.cyan)
ground = Entity(model='plane', scale=50, texture='white_cube')

def update():
    player.x += (held_keys['d'] - held_keys['a']) * time.dt * 5
    player.z += (held_keys['w'] - held_keys['s']) * time.dt * 5

app.run()
