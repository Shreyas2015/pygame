import pygame
pygame.init()
screen=pygame.display.set_mode((400,300))
pygame.display.set_caption("Task 20: Inventory")
items=[1,2,3]
running=True
while running:
    for e in pygame.event.get():
        if e.type==pygame.QUIT: running=False
    screen.fill((0,0,0))
    for i in range(len(items)):
        pygame.draw.rect(screen,(0,255,0),(10+i*40,250,30,30))
    pygame.display.flip()
pygame.quit()
