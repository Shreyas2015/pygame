import pygame
pygame.init()
screen=pygame.display.set_mode((400,300))
pygame.display.set_caption("Task 15: Lives")
lives=3
running=True
while running:
    for e in pygame.event.get():
        if e.type==pygame.QUIT: running=False
        if e.type==pygame.KEYDOWN: lives-=1
    if lives<=0: running=False
pygame.quit()
