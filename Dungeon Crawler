# ── Camera ────────────────────────────────────────────────────────────────────
VIEW_W,VIEW_H=W,H-80
def get_camera(px,py):
    cam_x=int(px)-VIEW_W//2; cam_y=int(py)-VIEW_H//2
    cam_x=max(0,min(cam_x,MAPW*TILE-VIEW_W)); cam_y=max(0,min(cam_y,MAPH*TILE-VIEW_H))
    return cam_x,cam_y

# ── Draw map ──────────────────────────────────────────────────────────────────
def draw_map(surf,grid,cam_x,cam_y,discovered):
    c0=cam_x//TILE; r0=cam_y//TILE
    c1=min(MAPW,(cam_x+VIEW_W)//TILE+2); r1=min(MAPH,(cam_y+VIEW_H)//TILE+2)
    for r in range(r0,r1):
        for c in range(c0,c1):
            if not discovered[r][c]: continue
            tx=c*TILE-cam_x; ty=r*TILE-cam_y
            if grid[r][c]=='#':
                pygame.draw.rect(surf,WALL,(tx,ty,TILE,TILE))
                pygame.draw.rect(surf,WALL2,(tx,ty,TILE,TILE),1)
            else:
                pygame.draw.rect(surf,FLOOR,(tx,ty,TILE,TILE))
                pygame.draw.rect(surf,(35,30,50),(tx,ty,TILE,TILE),1)

def update_vision(discovered,pr,pc,radius=5):
    for dr in range(-radius,radius+1):
        for dc in range(-radius,radius+1):
            nr,nc=pr+dr,pc+dc
            if 0<=nr<MAPH and 0<=nc<MAPW and math.hypot(dr,dc)<=radius:
                discovered[nr][nc]=True

