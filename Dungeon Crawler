class Monster:
    def __init__(self,row,col,kind,floor=1):
        self.row,self.col=row,col; self.kind=kind
        cfg=ENEMY_TYPES.get(kind,ENEMY_TYPES['slime'])
        self.hp=cfg['hp']+floor*8; self.max_hp=self.hp
        self.atk=cfg['atk']+floor*2; self.spd=cfg['spd']
        self.col_=cfg['col']; self.radius=cfg['r']
        self.xp_val=cfg['xp']; self.gold_val=cfg['gold']; self.score_val=cfg['score']
        self.px=col*TILE+TILE//2; self.py=row*TILE+TILE//2
        self.path=[]; self.path_timer=0.0; self.atk_cd=0.0; self.pulse=rnd(0,6)
        self.alive=True

    def update(self,dt,grid,pr,pc,atk_callback):
        self.pulse+=dt*3; self.path_timer-=dt; self.atk_cd=max(0,self.atk_cd-dt)
        if self.path_timer<=0:
            self.path=bfs_path(grid,(self.row,self.col),(pr,pc)); self.path_timer=0.4
        if len(self.path)>1:
            nr,nc=self.path[1]
            self.row+=(nr-self.row)*self.spd; self.col+=(nc-self.col)*self.spd
            if abs(self.row-nr)<0.05 and abs(self.col-nc)<0.05:
                self.row,self.col=nr,nc; self.path.pop(0) if len(self.path)>1 else None
        self.px+=(self.col*TILE+TILE//2-self.px)*0.2
        self.py+=(self.row*TILE+TILE//2-self.py)*0.2
        # Attack
        if dist(self.px,self.py,pr*TILE+TILE//2,pc*TILE+TILE//2)<TILE*1.5 and self.atk_cd<=0:
            atk_callback(self.atk); self.atk_cd=1.2

    def take_damage(self,dmg):
        self.hp=max(0,self.hp-dmg); self.alive=self.hp>0

    def draw(self,surf,cam_x,cam_y):
        cx=int(self.px)-cam_x; cy=int(self.py)-cam_y
        g=abs(math.sin(self.pulse))*0.4+0.6
        s=pygame.Surface((60,60),pygame.SRCALPHA)
        pygame.draw.circle(s,(*self.col_,int(45*g)),(30,30),26); surf.blit(s,(cx-30,cy-30))
        pygame.draw.circle(surf,self.col_,(cx,cy),self.radius)
        pygame.draw.circle(surf,WHITE,(cx,cy),self.radius,2)
        if self.kind=='boss':
            for i in range(6):
                a=math.radians(self.pulse*20+i*60)
                pygame.draw.circle(surf,ORANGE,(cx+int(math.cos(a)*28),cy+int(math.sin(a)*28)),7)
        draw_bar(surf,cx-self.radius,cy-self.radius-8,self.radius*2,4,self.hp,self.max_hp,RED)

