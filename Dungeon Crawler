# ── Main ──────────────────────────────────────────────────────────────────────
def new_floor(floor_num,player=None):
    grid,rooms=generate_map()
    discovered=[[False]*MAPW for _ in range(MAPH)]
    start_r=rooms[0][1]+rooms[0][3]//2; start_c=rooms[0][0]+rooms[0][2]//2
    if player is None:
        player=Player(start_r,start_c)
    else:
        player.row,player.col=start_r,start_c
        player.px=player.col*TILE+TILE//2; player.py=player.row*TILE+TILE//2
    monsters=[]; items=[]; projectiles=[]
    kinds_by_floor=['slime','skeleton','vampire','golem']
    avail=kinds_by_floor[:min(floor_num,4)]
    for room in rooms[1:]:
        rc=room[1]+room[3]//2; cc=room[0]+room[2]//2
        count=rndint(1,3+floor_num)
        for _ in range(count):
            mr=room[1]+rndint(1,room[3]-1); mc=room[0]+rndint(1,room[2]-1)
            kind='boss' if floor_num%5==0 and room==rooms[-2] else random.choice(avail)
            monsters.append(Monster(mr,mc,kind,floor_num))
        if rnd(0,1)<0.5:
            idata=random.choice(ITEM_POOL)
            items.append(Item(room[1]+1,room[0]+1,dict(idata)))
    stairs_r=rooms[-1][1]+rooms[-1][3]//2; stairs_c=rooms[-1][0]+rooms[-1][2]//2
    stairs=Stairs(stairs_r,stairs_c)
    return grid,discovered,player,monsters,items,stairs

def main():
    state='menu'; floor=1
    grid=discovered=player=monsters=items=stairs=None
    particles=[]; floats=[]; inv_sel=0; lvl_choices=[]
    paused=False

    def start():
        nonlocal grid,discovered,player,monsters,items,stairs,floor,particles,floats
        floor=1
        grid,discovered,player,monsters,items,stairs=new_floor(floor)
        particles=[]; floats=[]

    while True:
        dt=min(clock.tick(60)/1000.0,0.05)
        for event in pygame.event.get():
            if event.type==pygame.QUIT: pygame.quit();sys.exit()
            if event.type==pygame.KEYDOWN:
                if event.key==pygame.K_ESCAPE:
                    if state=='inventory': state='game'
                    else: pygame.quit();sys.exit()
                if event.key==pygame.K_SPACE:
                    if state=='menu': start();state='game'
                    elif state=='gameover': start();state='game'
                    elif state=='game':
                        # Attack
                        dr,dc=player.facing
                        if player.atk_cd<=0:
                            player.atk_cd=0.4
                            for m in monsters:
                                if dist(m.px,m.py,player.px,player.py)<TILE*1.8:
                                    m.take_damage(player.atk)
                                    for _ in range(8): particles.append(Particle(m.px,m.py,m.col_))
                                    floats.append(FloatText(m.px,m.py-20,f"-{player.atk}",YELLOW))
                if event.key==pygame.K_e:
                    if state=='game':
                        # Spell - AoE
                        if player.mana>=20 and player.spell_cd<=0:
                            player.mana=max(0,player.mana-20); player.spell_cd=2.0
                            for m in monsters:
                                if dist(m.px,m.py,player.px,player.py)<TILE*3:
                                    dmg=player.atk*2; m.take_damage(dmg)
                                    for _ in range(10): particles.append(Particle(m.px,m.py,PURPLE))
                                    floats.append(FloatText(m.px,m.py-20,f"SPELL!",PURPLE))
                    elif state=='inventory':
                        if player.inv and inv_sel<len(player.inv):
                            item=player.inv[inv_sel]
                            if item['type']=='weapon': player.atk=player.atk-( player.equipped['weapon']['atk'] if player.equipped['weapon'] else 0)+item['atk'];player.equipped['weapon']=item
                            elif item['type']=='armor': player.defense=player.defense-(player.equipped['armor']['def'] if player.equipped['armor'] else 0)+item['def'];player.equipped['armor']=item
                            elif item['type'] in ('potion','elixir'):
                                if 'hp' in item: player.hp=min(player.max_hp,player.hp+item['hp'])
                                if 'mp' in item: player.mana=min(player.max_mana,player.mana+item['mp'])
                                player.inv.pop(inv_sel); inv_sel=max(0,inv_sel-1)
                if event.key==pygame.K_i:
                    if state=='game': state='inventory'
                    elif state=='inventory': state='game'
                if state=='inventory':
                    if event.key==pygame.K_DOWN: inv_sel=min(len(player.inv)-1,inv_sel+1)
                    if event.key==pygame.K_UP: inv_sel=max(0,inv_sel-1)
                if state=='levelup':
                    for i,ch in enumerate(lvl_choices):
                        if event.key==pygame.K_1+i:
                            name,key,val,col=ch
                            if key=='atk': player.atk+=val
                            elif key=='hp': player.max_hp+=val;player.hp=min(player.hp+val,player.max_hp)
                            elif key=='def': player.defense+=val
                            elif key=='mana': player.max_mana+=val;player.mana=min(player.mana+val,player.max_mana)
                            elif key=='spd': player.spd+=val
                            state='game'
                if event.key==pygame.K_p and state=='game': paused=not paused

        if state=='game' and not paused:
            keys=pygame.key.get_pressed()
            player.update(dt,grid,keys)
            update_vision(discovered,player.row,player.col)
            player.atk_cd=max(0,player.atk_cd-dt)

            dead_monsters=[]
            for m in monsters:
                def atk_player(dmg,m=m): player.take_damage(dmg)
                m.update(dt,grid,player.row,player.col,atk_player)
                if not m.alive:
                    dead_monsters.append(m)
                    player.score+=m.score_val; player.gold+=m.gold_val; player.kills+=1
                    for _ in range(12): particles.append(Particle(m.px,m.py,m.col_))
                    floats.append(FloatText(m.px,m.py-30,f"+{m.score_val}",GOLD))
                    if player.gain_xp(m.xp_val):
                        random.shuffle(LVL_CHOICES); lvl_choices=LVL_CHOICES[:3]; state='levelup'
            monsters=[m for m in monsters if m.alive]

            # Pick up items
            for it in items[:]:
                if player.row==it.row and player.col==it.col:
                    player.inv.append(it.data); items.remove(it)
                    floats.append(FloatText(player.px,player.py-30,it.data['name'],it.data['col']))
            for it in items: it.update(dt)
            stairs.update(dt)

            # Stairs
            if player.row==stairs.row and player.col==stairs.col:
                floor+=1; player.floor=floor
                player.score+=floor*50
                grid,discovered,player,monsters,items,stairs=new_floor(floor,player)

            for p in particles: p.update()
            particles=[p for p in particles if not p.dead()]
            for f in floats: f.update()
            floats=[f for f in floats if not f.dead()]
            if player.hp<=0: state='gameover'

        # Draw
        screen.fill(BG)
        if state=='menu':
            screen.fill(BG)
            draw_text(screen,"DUNGEON CRAWLER",FT,PURPLE,W//2,130)
            draw_text(screen,"Depths Below",F1,CYAN,W//2,215)
            lines=[("WASD","Move"),("SPACE","Attack"),("E","Cast Spell (AoE)"),("I","Inventory"),("Reach stairs ▲ to go deeper!","")]
            for i,(k,v) in enumerate(lines):
                draw_text(screen,k,F2,YELLOW,W//2-180,310+i*46)
                if v: draw_text(screen,v,F2,GRAY,W//2+60,310+i*46)
            draw_text(screen,"Press SPACE to Start",F1,WHITE,W//2,560)
        elif state=='gameover':
            screen.fill(BG)
            draw_text(screen,"YOU DIED",FT,RED,W//2,160)
            draw_text(screen,f"Score: {player.score}",F1,YELLOW,W//2,270)
            draw_text(screen,f"Floor: {player.floor}   Kills: {player.kills}   Gold: {player.gold}",F2,GRAY,W//2,350)
            draw_text(screen,"Press SPACE to Try Again",F1,WHITE,W//2,460)
        elif state=='inventory': draw_inventory(screen,player,inv_sel)
        elif state=='levelup': draw_levelup(screen,lvl_choices)
        elif state in ('game',):
            cam_x,cam_y=get_camera(player.px,player.py)
            draw_map(screen,grid,cam_x,cam_y,discovered)
            for it in items: it.draw(screen,cam_x,cam_y)
            stairs.draw(screen,cam_x,cam_y)
            for m in monsters: m.draw(screen,cam_x,cam_y)
            for p in particles: p.draw(screen)
            for f in floats: f.draw(screen)
            player.draw(screen,cam_x,cam_y)
            draw_hud(screen,player)
            if paused: draw_text(screen,"PAUSED — P to resume",F1,WHITE,W//2,H//2)

        pygame.display.flip()

if __name__=="__main__": main()
