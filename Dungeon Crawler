# ── Map generation ────────────────────────────────────────────────────────────
MAPW,MAPH=40,30
def generate_map():
    grid=[['#']*MAPW for _ in range(MAPH)]
    rooms=[]
    for _ in range(18):
        rw=rndint(4,9); rh=rndint(4,8)
        rx=rndint(1,MAPW-rw-1); ry=rndint(1,MAPH-rh-1)
        overlap=any(rx<r[0]+r[2]+1 and rx+rw>r[0]-1 and ry<r[1]+r[3]+1 and ry+rh>r[1]-1 for r in rooms)
        if not overlap:
            for y in range(ry,ry+rh):
                for x in range(rx,rx+rw): grid[y][x]='.'
            rooms.append((rx,ry,rw,rh))
    for i in range(len(rooms)-1):
        x1,y1=rooms[i][0]+rooms[i][2]//2,rooms[i][1]+rooms[i][3]//2
        x2,y2=rooms[i+1][0]+rooms[i+1][2]//2,rooms[i+1][1]+rooms[i+1][3]//2
        cx,cy=x1,y1
        while cx!=x2:
            grid[cy][cx]='.'; cx+=1 if cx<x2 else -1
        while cy!=y2:
            grid[cy][cx]='.'; cy+=1 if cy<y2 else -1
    return grid,rooms

def bfs_path(grid,start,goal):
    q=deque([(start,[start])]); seen={start}
    dirs=[(0,1),(1,0),(0,-1),(-1,0)]
    while q:
        (r,c),path=q.popleft()
        if (r,c)==goal: return path
        for dr,dc in dirs:
            nr,nc=r+dr,c+dc
            if 0<=nr<MAPH and 0<=nc<MAPW and (nr,nc) not in seen and grid[nr][nc]!=('#'):
                seen.add((nr,nc)); q.append(((nr,nc),path+[(nr,nc)]))
    return []

# ── Particle ──────────────────────────────────────────────────────────────────
class Particle:
    def __init__(self,x,y,col,spd=4,life=35):
        self.x,self.y=float(x),float(y)
        a=rnd(0,math.pi*2); s=rnd(spd*0.4,spd)
        self.vx=math.cos(a)*s; self.vy=math.sin(a)*s
        self.col=col; self.life=life; self.ml=life; self.r=rnd(2,4)
    def update(self): self.x+=self.vx;self.y+=self.vy;self.life-=1
    def dead(self): return self.life<=0
    def draw(self,surf):
        a=int(255*self.life/self.ml)
        s=pygame.Surface((10,10),pygame.SRCALPHA)
        pygame.draw.circle(s,(*self.col,a),(5,5),int(self.r)); surf.blit(s,(int(self.x)-5,int(self.y)-5))

class FloatText:
    def __init__(self,x,y,txt,col=WHITE):
        self.x,self.y=float(x),float(y);self.txt=txt;self.col=col;self.a=255;self.vy=-1.2
    def update(self): self.y+=self.vy;self.a-=5
    def dead(self): return self.a<=0
    def draw(self,surf):
        img=F2.render(self.txt,True,self.col);img.set_alpha(int(self.a))
        surf.blit(img,(int(self.x)-img.get_width()//2,int(self.y)))

# ── Player ────────────────────────────────────────────────────────────────────
class Player:
    def __init__(self,r,c):
        self.row,self.col=r,c; self.px=c*TILE+TILE//2; self.py=r*TILE+TILE//2
        self.hp=80;self.max_hp=80;self.atk=15;self.defense=2;self.spd=4
        self.xp=0;self.level=1;self.xp_next=80;self.gold=0
        self.inv=[];self.equipped={'weapon':None,'armor':None}
        self.atk_cd=0.0;self.move_cd=0.0;self.invincible=0.0
        self.score=0;self.floor=1;self.kills=0
        self.mana=50;self.max_mana=50;self.spell_cd=0.0
        self.facing=(0,1);self.pulse=0.0

    def update(self,dt,grid,keys):
        self.pulse+=dt*3;self.atk_cd=max(0,self.atk_cd-dt)
        self.move_cd=max(0,self.move_cd-dt);self.invincible=max(0,self.invincible-dt)
        self.spell_cd=max(0,self.spell_cd-dt)
        if self.move_cd<=0:
            mv=None
            if keys[pygame.K_LEFT] or keys[pygame.K_a]: mv=(0,-1)
            elif keys[pygame.K_RIGHT] or keys[pygame.K_d]: mv=(0,1)
            elif keys[pygame.K_UP] or keys[pygame.K_w]: mv=(-1,0)
            elif keys[pygame.K_DOWN] or keys[pygame.K_s]: mv=(1,0)
            if mv:
                dr,dc=mv; self.facing=mv
                nr,nc=self.row+dr,self.col+dc
                if 0<=nr<MAPH and 0<=nc<MAPW and grid[nr][nc]!=('#'):
                    self.row,self.col=nr,nc; self.move_cd=0.12
        self.px+=(self.col*TILE+TILE//2-self.px)*0.22
        self.py+=(self.row*TILE+TILE//2-self.py)*0.22

    def gain_xp(self,amount):
        self.xp+=amount
        if self.xp>=self.xp_next:
            self.xp-=self.xp_next;self.level+=1;self.xp_next=int(self.xp_next*1.4)
            self.max_hp+=15;self.hp=min(self.hp+20,self.max_hp);self.atk+=3
            return True
        return False

    def take_damage(self,dmg):
        if self.invincible>0: return
        dmg=max(1,dmg-self.defense); self.hp=max(0,self.hp-dmg); self.invincible=0.6

    def draw(self,surf,cam_x,cam_y):
        cx=int(self.px)-cam_x; cy=int(self.py)-cam_y
        # Glow
        g=abs(math.sin(self.pulse))*0.3+0.7
        s=pygame.Surface((50,50),pygame.SRCALPHA)
        pygame.draw.circle(s,(*CYAN,int(40*g)),(25,25),22); surf.blit(s,(cx-25,cy-25))
        if self.invincible>0 and int(self.invincible*8)%2==0: return
        # Body
        pygame.draw.circle(surf,BLUE,(cx,cy),13)
        pygame.draw.circle(surf,WHITE,(cx,cy),13,2)
        # Face
        dr,dc=self.facing
        fx,fy=cx+dc*6,cy+dr*6
        pygame.draw.circle(surf,WHITE,(fx,fy),4)
        # Weapon indicator
        pygame.draw.line(surf,YELLOW,(cx,cy),(cx+dc*16,cy+dr*16),3)
        draw_bar(surf,cx-12,cy-22,24,4,self.hp,self.max_hp,GREEN)

