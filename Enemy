import pygame
pygame.init()
screen=pygame.display.set_mode((800,600))
pygame.display.set_caption("Task 8: Enemy")
enemy=pygame.Rect(100,200,50,50)
speed=3
running=True
while running:
    for e in pygame.event.get():
        if e.type==pygame.QUIT: running=False
    enemy.x+=speed
    if enemy.x<100 or enemy.x>600: speed*=-1
    screen.fill((0,0,0))
    pygame.draw.rect(screen,(255,0,0),enemy)
    pygame.display.flip()
pygame.quit()
