W, H = 900, 650
screen = pygame.display.set_mode((W, H))
pygame.display.set_caption("Asteroid Blaster")
clock = pygame.time.Clock()

# Colors
BG       = (5, 5, 20)
WHITE    = (255, 255, 255)
GRAY     = (120, 120, 140)
BLUE     = (80, 160, 255)
CYAN     = (60, 220, 220)
RED      = (220, 60, 60)
ORANGE   = (230, 140, 40)
YELLOW   = (240, 210, 50)
GREEN    = (60, 210, 100)
PURPLE   = (160, 80, 220)
