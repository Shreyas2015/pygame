from ursina import *

app = Ursina()

class Block(Button):
    def __init__(self, position=(0,0,0)):
        super().__init__(
            parent=scene,
            position=position,
            model='cube',
            origin_y=0.5,
            texture='white_cube',
            color=color.green,
            scale=1
        )

    def input(self, key):
        if self.hovered:
            if key == 'right mouse down':
                Block(position=self.position + mouse.normal)
            if key == 'left mouse down':
                destroy(self)

for z in range(5):
    for x in range(5):
        Block(position=(x,0,z))

app.run()
