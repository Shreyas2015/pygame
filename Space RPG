# ── Wave spawning ─────────────────────────────────────────────────────────────
def spawn_wave(wave):
    enemies=[]
    edge_positions=lambda n:[(rndint(-50,-10) if rnd(0,1)<0.5 else rndint(W+10,W+50), rndint(0,H)) for _ in range(n)]
    kinds=['drone']*max(1,wave*2)+['fighter']*max(0,wave-1)+['tank']*max(0,wave-2)
    for k in kinds:
        side=rndint(0,3)
        if side==0: x,y=rnd(0,W),-50
        elif side==1: x,y=W+50,rnd(0,H)
        elif side==2: x,y=rnd(0,W),H+50
        else: x,y=-50,rnd(0,H)
        enemies.append(Enemy(x,y,k,wave))
    if wave%5==0:
        enemies.append(Enemy(W//2,-80,'boss',wave))
    return enemies

# ── Main ──────────────────────────────────────────────────────────────────────
def main():
    state='menu'
    ship=None; enemies=[]; bullets=[]; particles=[]; pickups=[]; floats=[]
    wave=0; wave_pause=0.0; upgrade_choices=[]; paused=False

    def start():
        nonlocal ship,enemies,bullets,particles,pickups,floats,wave,wave_pause
        ship=Ship(); enemies=[]; bullets=[]; particles=[]; pickups=[]; floats=[]
        wave=0; wave_pause=2.0

    def next_wave():
        nonlocal wave,wave_pause,enemies
        wave+=1; enemies=spawn_wave(wave)
        floats.append(FloatText(W//2,H//2-40,f"WAVE {wave}!",ORANGE))
        wave_pause=0.0

    while True:
        dt=min(clock.tick(60)/1000.0,0.05)
        for event in pygame.event.get():
            if event.type==pygame.QUIT: pygame.quit();sys.exit()
            if event.type==pygame.KEYDOWN:
                if event.key==pygame.K_ESCAPE: pygame.quit();sys.exit()
                if event.key==pygame.K_SPACE:
                    if state=='menu': start();state='game'
                    elif state=='gameover': start();state='game'
                    elif state=='game' and not paused and state!='upgrade':
                        for b in ship.shoot(): bullets.append(b)
                if event.key==pygame.K_p and state=='game': paused=not paused
                if state=='upgrade':
                    for i,ch in enumerate(upgrade_choices):
                        if event.key in (pygame.K_1+i,):
                            name,key,val,col=ch
                            if key=='hp': ship.max_hp+=val;ship.hp=min(ship.hp+val,ship.max_hp)
                            elif key=='shield': ship.max_shield+=val;ship.shield=ship.max_shield
                            elif key=='dmg': ship.dmg+=val
                            elif key=='fire': ship.fire_rate=max(0.08,ship.fire_rate-val)
                            elif key=='multi': ship.bullet_count=min(3,ship.bullet_count+1)
                            elif key=='homing': ship.homing=True
                            elif key=='spd': ship.spd+=val
                            elif key=='sregen': ship.shield_regen=0
                            state='game'

        if state=='game' and not paused:
            keys=pygame.key.get_pressed()
            ship.update(dt,keys)
            if keys[pygame.K_SPACE]:
                for b in ship.shoot(): bullets.append(b)
            wave_pause=max(0,wave_pause-dt)
            if wave_pause<=0 and not enemies:
                next_wave()
            for b in bullets: b.update(dt)
            bullets=[b for b in bullets if not b.dead()]
            new_enemies=[]
            for e in enemies:
                e.update(dt,ship.x,ship.y,bullets)
                hit=False
                for b in bullets[:]:
                    if b.owner=='player' and dist(b.x,b.y,e.x,e.y)<e.radius+b.size:
                        if e.take_damage(b.dmg):
                            ship.score+=e.score_val; ship.kills+=1
                            if ship.gain_xp(e.xp_val):
                                random.shuffle(UPGRADES)
                                upgrade_choices=UPGRADES[:3]; state='upgrade'
                            for _ in range(16): particles.append(Particle(e.x,e.y,e.col))
                            floats.append(FloatText(e.x,e.y,f"+{e.score_val}",YELLOW))
                            if rnd(0,1)<0.3: pickups.append(Pickup(e.x,e.y))
                            hit=True
                        if not ship.pierce:
                            try: bullets.remove(b)
                            except: pass
                        break
                if not hit: new_enemies.append(e)
                # Enemy-ship collision
                if ship.invincible<=0 and dist(ship.x,ship.y,e.x,e.y)<ship.radius+e.radius-4:
                    ship.take_damage(e.dmg//2)
                    for _ in range(8): particles.append(Particle(ship.x,ship.y,ORANGE))
            enemies=new_enemies
            # Player bullets hit check done; enemy bullets vs player
            for b in bullets[:]:
                if b.owner=='enemy' and dist(b.x,b.y,ship.x,ship.y)<ship.radius+b.size:
                    ship.take_damage(b.dmg)
                    for _ in range(6): particles.append(Particle(ship.x,ship.y,RED))
                    try: bullets.remove(b)
                    except: pass
            for p in pickups:
                p.update(dt)
                if dist(ship.x,ship.y,p.x,p.y)<ship.radius+14:
                    p.life=0
                    if p.kind=='health': ship.hp=min(ship.max_hp,ship.hp+30)
                    elif p.kind=='shield': ship.shield=min(ship.max_shield,ship.shield+25)
                    elif p.kind=='dmg_up': ship.dmg+=8
                    elif p.kind=='fire_up': ship.fire_rate=max(0.08,ship.fire_rate-0.03)
                    elif p.kind=='multi': ship.bullet_count=min(3,ship.bullet_count+1)
                    floats.append(FloatText(ship.x,ship.y-30,p.kind.upper()+"!",GREEN))
            pickups=[p for p in pickups if not p.dead()]
            for p in particles: p.update()
            particles=[p for p in particles if not p.dead()]
            for f in floats: f.update()
            floats=[f for f in floats if not f.dead()]
            if ship.hp<=0: state='gameover'

        # Draw
        screen.fill(BG)
        t=time.time()
        for sx,sy,br,phase in STARS:
            tw=0.7+0.3*math.sin(t*br+phase); c=int(br*120*tw)
            pygame.draw.circle(screen,(c,c,min(255,c+30)),(int(sx),int(sy)),1 if br<1 else 2)

        if state=='menu': draw_menu()
        elif state=='gameover': draw_gameover(ship.score if ship else 0,ship.kills if ship else 0,wave)
        elif state=='upgrade': draw_upgrade_screen(screen,ship,upgrade_choices)
        elif state=='game':
            for p in pickups: p.draw(screen)
            for e in enemies: e.draw(screen)
            for b in bullets: b.draw(screen)
            for p in particles: p.draw(screen)
            for f in floats: f.draw(screen)
            ship.draw(screen)
            boss=next((e for e in enemies if e.kind=='boss'),None)
            draw_hud(ship,wave,len(enemies),boss is not None,boss.hp if boss else 0,boss.max_hp if boss else 1)
            if paused:
                draw_text(screen,"PAUSED — P to resume",F1,WHITE,W//2,H//2)
            if wave_pause>0 and not enemies:
                draw_text(screen,f"Wave {wave+1} incoming...",F1,ORANGE,W//2,H//2)

        pygame.display.flip()

if __name__=="__main__": main()
