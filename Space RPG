def rnd(a,b): return random.uniform(a,b)
def rndint(a,b): return random.randint(a,b)
def dist(x1,y1,x2,y2): return math.hypot(x1-x2,y1-y2)

def draw_text(surf,txt,font,col,cx,cy,center=True):
    s=font.render(str(txt),True,col)
    if center: surf.blit(s,(cx-s.get_width()//2,cy-s.get_height()//2))
    else: surf.blit(s,(cx,cy))

def draw_bar(surf,x,y,w,h,val,mx,col,bg=(30,30,50)):
    pygame.draw.rect(surf,bg,(x,y,w,h),border_radius=3)
    if mx>0: pygame.draw.rect(surf,col,(x,y,int(w*val/mx),h),border_radius=3)

def glow_circle(surf,col,cx,cy,r,alpha=60):
    s=pygame.Surface((r*4,r*4),pygame.SRCALPHA)
    pygame.draw.circle(s,(*col,alpha),(r*2,r*2),r*2)
    surf.blit(s,(cx-r*2,cy-r*2))

# ── Particle ──────────────────────────────────────────────────────────────────
class Particle:
    def __init__(self,x,y,col,spd=5,life=40):
        self.x,self.y=float(x),float(y)
        a=rnd(0,math.pi*2); s=rnd(spd*0.4,spd)
        self.vx=math.cos(a)*s; self.vy=math.sin(a)*s
        self.col=col; self.life=life; self.maxl=life; self.r=rnd(2,5)
    def update(self):
        self.x+=self.vx; self.y+=self.vy; self.vy+=0.05; self.life-=1
    def dead(self): return self.life<=0
    def draw(self,surf):
        alpha=int(255*self.life/self.maxl)
        s=pygame.Surface((12,12),pygame.SRCALPHA)
        pygame.draw.circle(s,(*self.col,alpha),(6,6),int(self.r))
        surf.blit(s,(int(self.x)-6,int(self.y)-6))

class FloatText:
    def __init__(self,x,y,txt,col=WHITE):
        self.x,self.y=float(x),float(y); self.txt=txt; self.col=col
        self.alpha=255; self.vy=-1.5
    def update(self): self.y+=self.vy; self.alpha-=5
    def dead(self): return self.alpha<=0
    def draw(self,surf):
        img=F2.render(self.txt,True,self.col); img.set_alpha(int(self.alpha))
        surf.blit(img,(int(self.x)-img.get_width()//2,int(self.y)))

# ── Bullet ────────────────────────────────────────────────────────────────────
class Bullet:
    def __init__(self,x,y,ang,spd=700,dmg=10,col=YELLOW,owner='player',size=4):
        self.x,self.y=float(x),float(y)
        self.vx=math.sin(ang)*spd; self.vy=-math.cos(ang)*spd
        self.dmg=dmg; self.col=col; self.owner=owner; self.size=size
        self.life=1.5; self.trail=[]
    def update(self,dt):
        self.trail.append((self.x,self.y))
        if len(self.trail)>8: self.trail.pop(0)
        self.x+=self.vx*dt; self.y+=self.vy*dt; self.life-=dt
    def dead(self): return self.life<=0 or not(-20<self.x<W+20 and -20<self.y<H+20)
    def draw(self,surf):
        for i,(tx,ty) in enumerate(self.trail):
            a=int(80*(i+1)/len(self.trail))
            s=pygame.Surface((10,10),pygame.SRCALPHA)
            pygame.draw.circle(s,(*self.col,a),(5,5),3); surf.blit(s,(int(tx)-5,int(ty)-5))
        pygame.draw.circle(surf,self.col,(int(self.x),int(self.y)),self.size)

# ── Ship ──────────────────────────────────────────────────────────────────────
class Ship:
    def __init__(self):
        self.x,self.y=W/2,H/2; self.angle=0.0
        self.vx=self.vy=0.0; self.radius=16
        self.hp=100; self.max_hp=100
        self.shield=0; self.max_shield=50
        self.shield_regen=0.0
        self.invincible=0.0
        self.shoot_cd=0.0
        self.xp=0; self.level=1; self.xp_next=100
        self.score=0; self.kills=0
        # Upgrades
        self.dmg=10; self.fire_rate=0.22; self.spd=320; self.bullet_count=1
        self.pierce=False; self.homing=False
        self.thrust_parts=[]
        self.pulse=0.0

    def update(self,dt,keys):
        self.pulse+=dt*3
        if keys[pygame.K_LEFT] or keys[pygame.K_a]: self.angle-=200*dt
        if keys[pygame.K_RIGHT] or keys[pygame.K_d]: self.angle+=200*dt
        thrust=keys[pygame.K_UP] or keys[pygame.K_w]
        if thrust:
            rad=math.radians(self.angle)
            self.vx+=math.sin(rad)*self.spd*dt*1.2
            self.vy-=math.cos(rad)*self.spd*dt*1.2
            if rnd(0,1)<0.5:
                r2=math.radians(self.angle+180+rnd(-25,25))
                self.thrust_parts.append({'x':self.x-math.sin(math.radians(self.angle))*18,
                    'y':self.y+math.cos(math.radians(self.angle))*18,
                    'vx':math.sin(r2)*rnd(2,5),'vy':-math.cos(r2)*rnd(2,5),
                    'alpha':220,'col':random.choice([ORANGE,YELLOW,RED])})
        mx=500; spd=math.hypot(self.vx,self.vy)
        if spd>mx: self.vx=self.vx/spd*mx; self.vy=self.vy/spd*mx
        self.vx*=0.97; self.vy*=0.97
        self.x=(self.x+self.vx*dt)%W; self.y=(self.y+self.vy*dt)%H
        self.invincible=max(0,self.invincible-dt)
        self.shoot_cd=max(0,self.shoot_cd-dt)
        # Shield regen
        if self.shield<self.max_shield:
            self.shield_regen+=dt
            if self.shield_regen>3: self.shield=min(self.shield+5,self.max_shield)
        for p in self.thrust_parts:
            p['x']+=p['vx']; p['y']+=p['vy']; p['alpha']-=15
        self.thrust_parts=[p for p in self.thrust_parts if p['alpha']>0]

    def shoot(self):
        if self.shoot_cd>0: return []
        self.shoot_cd=self.fire_rate
        rad=math.radians(self.angle)
        bullets=[]
        offsets=[0] if self.bullet_count==1 else [-12,12] if self.bullet_count==2 else [-20,0,20]
        for off in offsets[:self.bullet_count]:
            r2=math.radians(self.angle+off)
            bullets.append(Bullet(self.x,self.y,r2,700,self.dmg,YELLOW,'player'))
        return bullets

    def take_damage(self,dmg):
        if self.invincible>0: return
        if self.shield>0:
            self.shield=max(0,self.shield-dmg); self.shield_regen=0
        else:
            self.hp=max(0,self.hp-dmg)
        self.invincible=0.5

    def gain_xp(self,amount):
        self.xp+=amount
        if self.xp>=self.xp_next:
            self.xp-=self.xp_next; self.level+=1
            self.xp_next=int(self.xp_next*1.4)
            return True
        return False

    def draw(self,surf):
        for p in self.thrust_parts:
            s=pygame.Surface((10,10),pygame.SRCALPHA)
            pygame.draw.circle(s,(*p['col'],int(p['alpha'])),(5,5),4)
            surf.blit(s,(int(p['x'])-5,int(p['y'])-5))
        if self.invincible>0 and int(self.invincible*8)%2==0: return
        rad=math.radians(self.angle)
        def rot(px,py):
            rx=px*math.cos(rad)-py*math.sin(rad); ry=px*math.sin(rad)+py*math.cos(rad)
            return (int(self.x+rx),int(self.y+ry))
        pts=[rot(0,-20),rot(-12,14),rot(0,8),rot(12,14)]
        glow_circle(surf,CYAN,int(self.x),int(self.y),20,30)
        pygame.draw.polygon(surf,CYAN,pts); pygame.draw.polygon(surf,WHITE,pts,2)
        if self.shield>0:
            a=int(40+30*abs(math.sin(self.pulse)))
            s=pygame.Surface((80,80),pygame.SRCALPHA)
            pygame.draw.circle(s,(*BLUE,a),(40,40),36)
            pygame.draw.circle(s,(*BLUE,180),(40,40),36,2)
            surf.blit(s,(int(self.x)-40,int(self.y)-40))

# ── Enemy types ───────────────────────────────────────────────────────────────
class Enemy:
    def __init__(self,x,y,kind='drone',wave=1):
        self.x,self.y=float(x),float(y); self.kind=kind
        cfg={'drone':(30,40,60,1,20,ORANGE,12),'fighter':(60,80,40,2,40,RED,16),
             'tank':(150,200,25,3,80,PURPLE,22),'boss':(500+wave*100,600+wave*100,18,5,200,PINK,36)}
        hp,mhp,spd,dmg,xpv,col,r=cfg.get(kind,cfg['drone'])
        self.hp=hp+wave*5; self.max_hp=self.hp; self.spd=spd; self.dmg=dmg
        self.xp_val=xpv; self.col=col; self.radius=r
        self.angle=rnd(0,360); self.shoot_cd=rnd(1,3)
        self.pulse=rnd(0,6); self.vx=self.vy=0.0
        self.score_val={'drone':50,'fighter':120,'tank':250,'boss':1000}.get(kind,50)

    def update(self,dt,sx,sy,bullets_out):
        self.pulse+=dt*3; self.shoot_cd-=dt
        dx=sx-self.x; dy=sy-self.y; d=math.hypot(dx,dy)
        if d>0:
            nx,ny=dx/d,dy/d
            if self.kind=='boss':
                self.x+=nx*self.spd*dt; self.y+=ny*self.spd*dt
                if self.shoot_cd<=0:
                    self.shoot_cd=0.8
                    for off in range(0,360,45):
                        r=math.radians(off)
                        bullets_out.append(Bullet(self.x,self.y,r,300,self.dmg,PINK,'enemy',6))
            elif self.kind=='tank':
                self.x+=nx*self.spd*dt; self.y+=ny*self.spd*dt
                if self.shoot_cd<=0:
                    self.shoot_cd=2.0
                    ang=math.atan2(dx,dy); bullets_out.append(Bullet(self.x,self.y,-ang+math.pi,350,self.dmg*2,PURPLE,'enemy',7))
            else:
                self.x+=nx*self.spd*dt; self.y+=ny*self.spd*dt
                if self.shoot_cd<=0:
                    self.shoot_cd=1.5 if self.kind=='fighter' else 2.5
                    ang=math.atan2(dx,dy); bullets_out.append(Bullet(self.x,self.y,-ang+math.pi,450,self.dmg,RED,'enemy',5))
        self.x=max(0,min(W,self.x)); self.y=max(0,min(H,self.y))

    def take_damage(self,dmg): self.hp-=dmg; return self.hp<=0

    def draw(self,surf):
        glow=abs(math.sin(self.pulse))*0.4+0.6
        cx,cy=int(self.x),int(self.y)
        glow_circle(surf,self.col,cx,cy,self.radius,int(50*glow))
        pygame.draw.circle(surf,self.col,(cx,cy),self.radius)
        pygame.draw.circle(surf,WHITE,(cx,cy),self.radius,2)
        if self.kind=='boss':
            for i in range(4):
                a=math.radians(self.pulse*30+i*90)
                ex,ey=cx+int(math.cos(a)*28),cy+int(math.sin(a)*28)
                pygame.draw.circle(surf,PINK,(ex,ey),8)
        draw_bar(surf,cx-self.radius,cy-self.radius-8,self.radius*2,4,self.hp,self.max_hp,GREEN)

# ── Powerup ───────────────────────────────────────────────────────────────────
class Pickup:
    KINDS=['health','shield','dmg_up','fire_up','multi']
    COLS={'health':RED,'shield':BLUE,'dmg_up':YELLOW,'fire_up':GREEN,'multi':PURPLE}
    LBLS={'health':'HP','shield':'SH','dmg_up':'DMG','fire_up':'SPD','multi':'X3'}
    def __init__(self,x,y):
        self.x,self.y=float(x),float(y)
        self.kind=random.choice(self.KINDS); self.pulse=rnd(0,6); self.life=10.0
    def update(self,dt): self.pulse+=dt*3; self.life-=dt
    def dead(self): return self.life<=0
    def draw(self,surf):
        g=abs(math.sin(self.pulse))*0.5+0.5; col=self.COLS[self.kind]
        cx,cy=int(self.x),int(self.y)
        s=pygame.Surface((40,40),pygame.SRCALPHA)
        pygame.draw.circle(s,(*col,int(60*g)),(20,20),18); surf.blit(s,(cx-20,cy-20))
        pygame.draw.circle(surf,col,(cx,cy),12); pygame.draw.circle(surf,WHITE,(cx,cy),12,2)
        t=F3.render(self.LBLS[self.kind],True,WHITE); surf.blit(t,(cx-t.get_width()//2,cy-t.get_height()//2))

