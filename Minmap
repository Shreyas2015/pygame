import pygame
pygame.init()
screen=pygame.display.set_mode((400,300))
pygame.display.set_caption("Task 22: Minimap")
p=[200,150]
running=True
while running:
    for e in pygame.event.get():
        if e.type==pygame.QUIT: running=False
    pygame.draw.circle(screen,(255,0,0),(p[0]//4,p[1]//4),3)
    pygame.display.flip()
pygame.quit()
